# F100 COUNCIL / ecosystem-sim — copy to .env (DO NOT COMMIT .env)
# Register accounts per docs/ENV-KEYS-REGISTER.md
# Audit: bash scripts/env-audit.sh

# ── Ops flags ──────────────────────────────────────────────
ENABLE_BACKEND_OODA=0
BACKEND_OODA_SLEEP_SEC=60
WORKER_LOOP_SLEEP_SEC=300
MINER_MIN_INTERVAL_SEC=300
MINER_MAX_AUDITS_PER_HOUR=12
